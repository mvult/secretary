{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Secretary Outline",
  "version": "0.1.0",
  "identifier": "com.secretary.native",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Secretary Outline",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
